# Copia este archivo a .env.local y llena los valores.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Llave secreta (service_role). Solo se usa del lado del servidor, en /admin
# y en el script de importación. Nunca la expongas al navegador.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# PIN de 4 dígitos para entrar a /admin.
# Tras 5 intentos fallidos, esa IP queda bloqueada 15 minutos.
ADMIN_PIN=0000

# Dominio público, para armar las ligas de cada invitado
NEXT_PUBLIC_SITE_URL=https://emma.tudominio.com
